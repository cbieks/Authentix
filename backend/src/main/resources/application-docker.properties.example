# Docker MySQL + Flyway (team default).
# Copy this file to application-docker.properties (same folder) and set your password.
# application-docker.properties is gitignored — never commit it.
#
# 1. From repo root: copy .env.example → .env and set MYSQL_* (must match password below).
# 2. docker compose up -d
# 3. Run backend: $env:SPRING_PROFILES_ACTIVE = docker; .\mvnw.cmd spring-boot:run

spring.flyway.enabled=true
spring.flyway.locations=classpath:db/migration

spring.jpa.hibernate.ddl-auto=validate

# Host port from docker-compose.yml (default 3307 if MySQL 9.x uses 3306 on the host).
spring.datasource.url=jdbc:mysql://localhost:3307/authentix?useUnicode=true&characterEncoding=utf8
spring.datasource.username=authentix
spring.datasource.password=CHANGE_ME_MATCH_MYSQL_PASSWORD_IN_DOT_ENV

# Optional: Stripe (Connect / checkout)
# stripe.secret-key=sk_test_...
# stripe.webhook-secret=whsec_...
# stripe.connect.success-url=http://localhost:5173/account?stripe=success
# stripe.connect.refresh-url=http://localhost:5173/account?stripe=refresh
